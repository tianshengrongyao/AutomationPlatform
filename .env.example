ARK_API_KEY=replace-with-your-api-key
ARK_MODEL_ID=seedance-2.0-vision-1080
SITE_PASSWORD=replace-with-a-team-password
SESSION_SECRET=replace-with-a-long-random-secret

# Leave this empty for official Volcengine Ark.
# For a non-official/proxy key, ask for the matching Base URL and put it here.
ARK_BASE_URL=
ARK_CREATE_TASK_PATH=/contents/generations/tasks
ARK_QUERY_TASK_PATH=/contents/generations/tasks/{id}
